FROM node:22-slim

WORKDIR /app

# Copy package files
COPY package.json package-lock.json ./

# Install dependencies
RUN npm install

# Copy source code
COPY . .

# Set environment variables
ENV PORT=3001
# We allow the API_URL to be passed at build time or overridden at runtime
ENV REACT_APP_API_URL=http://localhost:8000/api

EXPOSE 3001

CMD ["npm", "start"]
